APP_ENV=dev
APP_NAME=case-pilot-backend
API_PREFIX=/api
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=chrome-extension://.*
LOCAL_STORAGE_PATH=./storage
STORE_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://casepilot:casepilot@localhost:5432/casepilot
POSTGRES_POOL_MIN_SIZE=1
POSTGRES_POOL_MAX_SIZE=10
REDIS_URL=redis://localhost:6379/0
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=casepilot_documents
EMBEDDING_PROVIDER=local-hash
EMBEDDING_DIMENSIONS=384
OMNIPARSER_URL=http://127.0.0.1:8001
OCR_ENGINE=omniparser
OCR_FALLBACK_TO_MOCK=true
OBD_SOURCE_MODE=mock
OBD_WS_URL=ws://127.0.0.1:4455
OBD_WS_PASSWORD=
OBD_SOURCE_NAME=
OBD_FRAME_WIDTH=1280
LLM_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
ESP32_BRIDGE_MODE=mock
ESP32_BASE_URL=http://192.168.31.234
ESP32_WS_URL=ws://192.168.31.234:81/hid
ESP32_API_TOKEN=change-me
ESP32_COMMAND_TIMEOUT_MS=5000
CHROME_PLUGIN_TOKEN=change-me
